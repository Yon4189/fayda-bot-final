<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Super Admin Dashboard — Fayda Bot</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg: #0f0f12;
            --surface: #18181c;
            --surface2: #1f1f24;
            --text: #e4e4e7;
            --muted: #a1a1aa;
            --accent: #6366f1;
            --accent-hover: #818cf8;
            --danger: #ef4444;
            --warning: #f59e0b;
            --success: #22c55e;
            --radius: 12px;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            line-height: 1.5;
        }

        /* Header */
        .header {
            background: var(--surface);
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            padding: 1rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .header h1 {
            font-size: 1.25rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .header nav {
            display: flex;
            gap: 0.5rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .badge {
            font-size: 0.65rem;
            background: var(--accent);
            color: white;
            padding: 0.15rem 0.5rem;
            border-radius: 999px;
            font-weight: 500;
            letter-spacing: 0.03em;
        }

        /* Container */
        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 1.5rem;
        }

        /* Stats Grid */
        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: var(--radius);
            padding: 1.25rem;
            transition: transform 0.15s, border-color 0.15s;
        }

        .stat-card:hover {
            transform: translateY(-2px);
            border-color: rgba(99, 102, 241, 0.3);
        }

        .stat-card h3 {
            color: var(--muted);
            font-size: 0.7rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-bottom: 0.5rem;
        }

        .stat-card .number {
            font-size: 1.75rem;
            font-weight: 700;
        }

        /* Card */
        .card {
            background: var(--surface);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: var(--radius);
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .card h2 {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 1rem;
        }

        /* Forms */
        .form-inline {
            display: flex;
            flex-wrap: wrap;
            align-items: flex-end;
            gap: 0.75rem;
        }

        .form-inline label {
            display: block;
            font-size: 0.75rem;
            color: var(--muted);
            margin-bottom: 0.25rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .form-inline input {
            background: var(--surface2);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            padding: 0.5rem 0.75rem;
            color: var(--text);
            font-size: 0.9rem;
            font-family: inherit;
            width: 160px;
            transition: border-color 0.15s;
        }

        .form-inline input:focus {
            outline: none;
            border-color: var(--accent);
        }

        /* Buttons */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 500;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: all 0.15s;
            font-family: inherit;
        }

        .btn-primary {
            background: var(--accent);
            color: white;
        }

        .btn-primary:hover {
            background: var(--accent-hover);
            transform: translateY(-1px);
        }

        .btn-ghost {
            background: transparent;
            color: var(--muted);
        }

        .btn-ghost:hover {
            color: var(--text);
            background: rgba(255, 255, 255, 0.05);
        }

        .btn-danger {
            background: var(--danger);
            color: white;
        }

        .btn-danger:hover {
            opacity: 0.9;
        }

        /* Table */
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        th {
            text-align: left;
            padding: 0.75rem 1rem;
            color: var(--muted);
            font-weight: 500;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        }

        td {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        }

        tr:hover td {
            background: rgba(255, 255, 255, 0.02);
        }

        .expiring {
            color: var(--warning);
        }

        .expired {
            color: var(--danger);
        }

        /* Feedback */
        .msg {
            font-size: 0.85rem;
            margin-top: 0.5rem;
        }

        .msg.err {
            color: var(--danger);
        }

        /* Toolbar */
        .toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 2rem 1rem 1rem;
            color: var(--muted);
            font-size: 0.7rem;
            letter-spacing: 0.03em;
        }

        /* ===== Mobile Responsive ===== */
        @media (max-width: 768px) {
            .header {
                padding: 0.75rem 1rem;
            }

            .header h1 {
                font-size: 1.1rem;
            }

            .container {
                padding: 1rem;
            }

            .stats {
                grid-template-columns: 1fr 1fr;
                gap: 0.75rem;
            }

            .stat-card {
                padding: 1rem;
            }

            .stat-card .number {
                font-size: 1.5rem;
            }

            /* Table → Card Layout */
            table,
            thead,
            tbody,
            th,
            td,
            tr {
                display: block;
            }

            thead {
                display: none;
            }

            tbody tr {
                background: var(--surface2);
                border-radius: 10px;
                padding: 1rem;
                margin-bottom: 0.75rem;
                border: 1px solid rgba(255, 255, 255, 0.04);
            }

            tbody tr:hover td {
                background: transparent;
            }

            td {
                padding: 0.25rem 0;
                border: none;
                font-size: 0.85rem;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            td::before {
                content: attr(data-label);
                font-weight: 500;
                color: var(--muted);
                font-size: 0.7rem;
                text-transform: uppercase;
                letter-spacing: 0.04em;
                flex-shrink: 0;
                margin-right: 0.75rem;
            }

            td:last-child {
                margin-top: 0.5rem;
                justify-content: flex-end;
            }

            /* Form */
            .form-inline {
                flex-direction: column;
                align-items: stretch;
            }

            .form-inline input {
                width: 100%;
            }

            .btn {
                justify-content: center;
            }
        }

        @media (max-width: 480px) {
            .stats {
                grid-template-columns: 1fr;
            }

            .header nav {
                width: 100%;
                justify-content: space-between;
            }
        }
    </style>
</head>

<body>
    <header class="header">
        <h1>Fayda Bot <span class="badge">Super Admin</span></h1>
        <nav>
            <a href="/broadcast" class="btn btn-ghost">📢 Broadcast</a>
            <a href="/pending" class="btn btn-ghost">📋 Pending</a>
            <a href="/revoked" class="btn btn-ghost">⛔ Revoked<% if (stats.revokedCount) { %> (<%= stats.revokedCount %>
                        )<% } %></a>
            <a href="/export-users" class="btn btn-ghost">📥 Export</a>
            <a href="/logout" class="btn btn-ghost">🚪 Log out</a>
        </nav>
    </header>
    <main class="container">
        <div class="stats">
            <div class="stat-card">
                <h3>Total Users</h3>
                <div class="number">
                    <%= stats.totalUsers %>
                </div>
            </div>
            <div class="stat-card">
                <h3>Admins</h3>
                <div class="number">
                    <%= stats.admins %>
                </div>
            </div>
            <div class="stat-card">
                <h3>Sub Users</h3>
                <div class="number">
                    <%= stats.subUsers %>
                </div>
            </div>
            <div class="stat-card">
                <h3>Expiring Soon</h3>
                <div class="number">
                    <%= stats.expiringSoon %>
                </div>
            </div>
            <div class="stat-card">
                <h3>Total Downloads</h3>
                <div class="number">
                    <%= stats.totalDownloads %>
                </div>
            </div>
            <div class="stat-card">
                <h3>Revoked</h3>
                <div class="number" style="color: var(--danger)">
                    <%= stats.revokedCount %>
                </div>
            </div>
        </div>

        <div class="card"
            style="border-color: <%= maintenance.enabled ? 'var(--danger)' : 'rgba(255,255,255,0.06)' %>;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                <h2 style="margin: 0; color: <%= maintenance.enabled ? 'var(--danger)' : 'inherit' %>">
                    🛠️ Maintenance Mode: <%= maintenance.enabled ? 'ON' : 'OFF' %>
                </h2>
                <form method="POST" action="/maintenance/toggle" style="margin: 0;"
                    onsubmit="return confirm('<%= maintenance.enabled ? 'Disable maintenance mode and notify all users?' : 'Turn ON maintenance mode? Regular users will be blocked.' %>');">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn <%= maintenance.enabled ? 'btn-danger' : 'btn-outline' %>"
                        style="<%= !maintenance.enabled ? 'border: 1px solid var(--muted);' : '' %>">
                        Turn <%= maintenance.enabled ? 'OFF' : 'ON' %>
                    </button>
                </form>
            </div>
            <p class="msg" style="color: var(--muted); margin-bottom: 1rem;">
                When active, only users in the bypass list below can access the bot. Others will see a maintenance
                message.
            </p>

            <form method="POST" action="/maintenance/add-bypass" class="form-inline" style="margin-bottom: 1rem;">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div>
                    <input type="text" name="telegramId" placeholder="Telegram ID to bypass" required id="bypassInput">
                </div>
                <button type="button" class="btn btn-outline" style="border: 1px solid var(--muted);"
                    onclick="document.getElementById('bypassInput').value = '<%= admin ? admin.telegramId : '' %>'">Auto-fill
                    ID</button>
                <button type="submit" class="btn btn-primary">Add to Bypass</button>
            </form>

            <% if (maintenance.allowedUsers && maintenance.allowedUsers.length> 0) { %>
                <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
                    <% maintenance.allowedUsers.forEach(userId=> { %>
                        <div
                            style="background: var(--surface2); padding: 0.25rem 0.75rem; border-radius: 99px; font-size: 0.8rem; display: flex; align-items: center; gap: 0.5rem; border: 1px solid rgba(255,255,255,0.1);">
                            <%= userId %>
                                <form method="POST" action="/maintenance/remove-bypass/<%= userId %>"
                                    style="margin: 0;">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <button type="submit"
                                        style="background: none; border: none; color: var(--danger); cursor: pointer; font-weight: bold;">&times;</button>
                                </form>
                        </div>
                        <% }) %>
                </div>
                <% } else { %>
                    <span style="font-size: 0.8rem; color: var(--muted);">No users in bypass list.</span>
                    <% } %>
        </div>

        <div class="card">
            <h2>➕ Add Admin</h2>
            <form method="POST" action="/add-buyer" class="form-inline">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div>
                    <label>Telegram ID</label>
                    <input type="text" name="telegramId" placeholder="5434080792" required autocomplete="off">
                </div>
                <div>
                    <label>Expiry (days)</label>
                    <input type="number" name="expiryDays" value="30" min="1">
                </div>
                <div>
                    <label>Max Sub-Users</label>
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <input type="number" id="maxSubUsersInput" value="9" min="0" style="width: 100px;">
                        <input type="hidden" id="maxSubUsersHidden" name="maxSubUsers" value="9">
                        <label
                            style="margin: 0; display: flex; align-items: center; gap: 0.25rem; font-size: 0.8rem; text-transform: none; color: var(--text);">
                            <input type="checkbox" id="unlimitedSubsToggle" style="width: auto;"> Unlimited
                        </label>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary">Add Admin</button>

                <script>
                    const unlimitedToggle = document.getElementById('unlimitedSubsToggle');
                    const maxSubUsersInput = document.getElementById('maxSubUsersInput');
                    const maxSubUsersHidden = document.getElementById('maxSubUsersHidden');

                    // Keep hidden input in sync when typing manually
                    maxSubUsersInput.addEventListener('input', (e) => {
                        maxSubUsersHidden.value = e.target.value;
                    });

                    unlimitedToggle.addEventListener('change', (e) => {
                        if (e.target.checked) {
                            maxSubUsersInput.type = 'text';
                            maxSubUsersInput.disabled = true;
                            maxSubUsersInput.value = 'Unlimited';
                            maxSubUsersHidden.value = '-1';
                        } else {
                            maxSubUsersInput.type = 'number';
                            maxSubUsersInput.disabled = false;
                            maxSubUsersInput.value = '9';
                            maxSubUsersHidden.value = '9';
                        }
                    });
                </script>
                <% if (typeof error !=='undefined' && error) { %>
                    <p class="msg err">
                        <%= error==='user_must_start' ? 'User must send /start first' : error==='invalid_id'
                            ? 'Invalid Telegram ID' : error==='already_added' ? 'Already an admin' : error %>
                    </p>
                    <% } %>
            </form>
        </div>
        <div class="card">
            <div class="toolbar">
                <h2>👑 Admins</h2>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Own PDFs</th>
                        <th>Users' PDFs</th>
                        <th>Total</th>
                        <th>Users</th>
                        <th>Expiry</th>
                        <th>Last Active</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <% admins.forEach(b=> { %>
                        <tr>
                            <td data-label="ID"><code><%= b.telegramId %></code></td>
                            <td data-label="Name">
                                <%= b.firstName || '—' %>
                                    <%= b.lastName || '' %>
                            </td>
                            <td data-label="Own PDFs">
                                <%= b.downloadCount || 0 %>
                            </td>
                            <td data-label="Users' PDFs">
                                <%= b.subDownloads + (b.archived || 0) %>
                            </td>
                            <td data-label="Total">
                                <%= b.totalDownloads %>
                            </td>
                            <td data-label="Users">
                                <% if (b.maxSubUsers===-1) { %>
                                    Unlimited
                                    <% } else { %>
                                        <%= b.subUsers ? b.subUsers.length : 0 %> / <%= b.maxSubUsers ?? 9 %>
                                                <% } %>
                            </td>
                            <td data-label="Expiry"
                                class="<%= new Date(b.expiryDate) < new Date() ? 'expired' : (new Date(b.expiryDate) < new Date(Date.now() + 7*24*60*60*1000) ? 'expiring' : '') %>">
                                <%= b.expiryDate ? new Date(b.expiryDate).toLocaleDateString() : '—' %>
                            </td>
                            <td data-label="Last Active">
                                <%= b.lastActive ? new Date(b.lastActive).toLocaleDateString() : 'Never' %>
                            </td>
                            <td><a href="/buyer/<%= b.telegramId %>" class="btn btn-primary">⚙️ Manage</a></td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </main>
    <footer class="footer">Fayda Bot Admin Dashboard</footer>
</body>

</html>